{
  "name": "Ubora Cloud Desktop Client",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",  // Linux recommandé
  "features": {
    "ghcr.io/devcontainers/features/cmake:1": {},
    "ghcr.io/devcontainers/features/qt:1": {},           // Framework Qt
    "ghcr.io/devcontainers/features/gcc:1": {}           // Compilateur C++
  },
  "forwardPorts": [3000],  // Utile pour un éventuel debug HTTP
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y git-buildpackage debhelper",  // Outils pour packages .deb
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",           // Extension C++
        "twxs.cmake",                   // CMake support
        "nico-castell.linux-desktop-file"  // Pour les fichiers .desktop
      ]
    }
  }
}